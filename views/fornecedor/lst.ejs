<%- include('../cabecalho.ejs')%>
 <main class="container">
        <div class="page-header">
            <h2>Lista de Fornecedores</h2>
            <a href="/fornecedor/add" class="btn btn-success">+ Novo Fornecedor</a>
            <form method="post"> </br>
                <div class="form-group">
                <input type="text" name="pesquisar" placeholder="Nome do Fornecedor">
                <input class="btn btn-success" type="submit" value="Buscar">
              </div>
            </form>
        </div>

 <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th>Telefone</th>
                        <th>Excluir</th>
                        <th>Editar</th>
                    </tr>
                </thead>
                <tbody> 
                    <% fornecedores.forEach(fornecedor => { %>
                        <tr>
                            <td><%= fornecedor.nome %></td>
                            <td><%= fornecedor.telefone %></td>
                            <td><a href="/fornecedor/del/<%= fornecedor.id %>" class="link">EXCLUIR</a></td>
                            <td><a href="/fornecedor/edt/<%= fornecedor.id %>" class="link">EDITAR</a></td>
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </main>

<%- include('../rodape.ejs')%>